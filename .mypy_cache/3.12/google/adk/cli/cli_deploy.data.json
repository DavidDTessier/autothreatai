{".class":"MypyFile","_fullname":"google.adk.cli.cli_deploy","future_import_flags":["annotations"],"is_partial_stub_package":false,"is_stub":false,"names":{".class":"SymbolTable","Final":{".class":"SymbolTableNode","cross_ref":"typing.Final","kind":"Gdef"},"Optional":{".class":"SymbolTableNode","cross_ref":"typing.Optional","kind":"Gdef"},"_AGENT_ENGINE_APP_TEMPLATE":{".class":"SymbolTableNode","kind":"Gdef","node":{".class":"Var","final_value":"\nimport os\nimport vertexai\nfrom vertexai.agent_engines import AdkApp\n\nif {is_config_agent}:\n  from google.adk.agents import config_agent_utils\n  try:\n    # This path is for local loading.\n    root_agent = config_agent_utils.from_config(\"{agent_folder}/root_agent.yaml\")\n  except FileNotFoundError:\n    # This path is used to support the file structure in Agent Engine.\n    root_agent = config_agent_utils.from_config(\"./{temp_folder}/{app_name}/root_agent.yaml\")\nelse:\n  from .agent import {adk_app_object}\n\nif {express_mode}: # Whether or not to use Express Mode\n  vertexai.init(api_key=os.environ.get(\"GOOGLE_API_KEY\"))\nelse:\n  vertexai.init(\n    project=os.environ.get(\"GOOGLE_CLOUD_PROJECT\"),\n    location=os.environ.get(\"GOOGLE_CLOUD_LOCATION\"),\n  )\n\nadk_app = AdkApp(\n    {adk_app_type}={adk_app_object},\n    enable_tracing={trace_to_cloud_option},\n)\n","flags":["is_final","is_ready","has_explicit_value"],"fullname":"google.adk.cli.cli_deploy._AGENT_ENGINE_APP_TEMPLATE","name":"_AGENT_ENGINE_APP_TEMPLATE","setter_type":null,"type":"builtins.str"}},"_AGENT_ENGINE_CLASS_METHODS":{".class":"SymbolTableNode","kind":"Gdef","node":{".class":"Var","flags":["is_ready","is_inferred","has_explicit_value"],"fullname":"google.adk.cli.cli_deploy._AGENT_ENGINE_CLASS_METHODS","name":"_AGENT_ENGINE_CLASS_METHODS","setter_type":null,"type":{".class":"Instance","args":[{".class":"Instance","args":["builtins.str",{".class":"Instance","args":["builtins.str"],"extra_attrs":null,"type_ref":"typing.Collection"}],"ext